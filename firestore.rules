rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /meetings/{meetingId} {
      allow read, write: if true;
    }

    match /settings/config {
      allow read, write: if true;
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['id', 'department', 'content', 'date', 'startTime', 'endTime']) &&
             data.id is string && data.id.size() <= 128 &&
             data.department is string && data.department.size() <= 100 &&
             data.content is string && data.content.size() <= 500 &&
             data.date is timestamp &&
             data.startTime is string && data.startTime.matches('^[0-9]{2}:[0-9]{2}$') &&
             data.endTime is string && data.endTime.matches('^[0-9]{2}:[0-9]{2}$') &&
             (data.get('topic', '') is string && data.get('topic', '').size() <= 500) &&
             (data.get('location', '') is string && data.get('location', '').size() <= 500) &&
             (data.get('remarks', '') is string && data.get('remarks', '').size() <= 2000) &&
             (data.get('advisors', []) is list) &&
             (data.get('updatedAt', request.time) is timestamp);
    }

    function isValidSettings(data) {
      return (data.get('advisors', []) is list) &&
             (data.get('locations', []) is list) &&
             (data.get('participants', []) is list) &&
             (data.get('updatedAt', request.time) is timestamp);
    }
  }
}
