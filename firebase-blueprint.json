{
  "entities": {
    "Meeting": {
      "title": "Meeting",
      "description": "A scheduled meeting for the hospital department",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "department": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "isAutoGenerated": { "type": "boolean" },
        "groupId": { "type": "string" },
        "topic": { "type": "string" },
        "location": { "type": "string" },
        "advisors": { "type": "array", "items": { "type": "string" } },
        "presenter": { "type": "string" },
        "recorder": { "type": "string" },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "department", "content", "date", "startTime", "endTime"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Application-wide settings",
      "type": "object",
      "properties": {
        "advisors": { "type": "array", "items": { "type": "string" } },
        "locations": { "type": "array", "items": { "type": "string" } },
        "participants": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Collection of all hospital meetings"
    },
    "/settings/config": {
      "schema": "AppSettings",
      "description": "Global application configuration"
    }
  }
}
